// app.aero — Sample Aero application entry point
// Demonstrates core language features: variables, functions, control flow.

fn add(a, b) {
    return a + b;
}

fn factorial(n) {
    if n <= 1 {
        return 1;
    }
    return n * factorial(n - 1);
}

let x = 10;
let y = 20;
let sum = add(x, y);
print(sum);

let fact5 = factorial(5);
print(fact5);
